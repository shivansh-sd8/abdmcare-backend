generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String        @id @default(uuid())
  uhid             String        @unique
  
  // ABDM Identity (Cross-Hospital)
  abhaId           String?       @unique
  abhaAddress      String?
  abhaNumber       String?       @unique
  
  // Basic Info
  firstName        String
  lastName         String
  gender           Gender
  dob              DateTime?
  mobile           String        @unique
  email            String?
  address          Json
  bloodGroup       String?
  emergencyContact Json?
  
  // Hospital that registered the patient
  // Patient data can be shared across hospitals via ABDM Consent model
  hospitalId       String?
  hospital         Hospital?     @relation(fields: [hospitalId], references: [id])
  
  isActive         Boolean       @default(true)
  
  // Relations
  abhaRecord       AbhaRecord?
  encounters       Encounter[]
  consents         Consent[]
  appointments     Appointment[]
  careContexts     CareContext[]
  prescriptions    Prescription[]
  vitals           Vitals[]
  investigations   Investigation[]
  payments         Payment[]
  admissions       Admission[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  @@index([abhaId])
  @@index([abhaNumber])
  @@index([mobile])
  @@index([uhid])
  @@index([hospitalId])
  @@map("patients")
}

model AbhaRecord {
  id              String    @id @default(uuid())
  abhaNumber      String    @unique
  abhaAddress     String?
  patientId       String?   @unique
  
  aadhaarLinked   Boolean   @default(false)
  mobileLinked    Boolean   @default(false)
  
  kycStatus       KycStatus @default(PENDING)
  profileData     Json?
  
  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([abhaNumber])
  @@map("abha_records")
}

model Doctor {
  id              String        @id @default(uuid())
  hprId           String?       @unique
  firstName       String
  lastName        String
  specialization  String
  qualification   String
  registrationNo  String        @unique
  mobile          String
  email           String
  isActive        Boolean       @default(true)
  consultationFee Decimal?      @db.Decimal(10, 2)   // OPD fee set by admin
  
  hospitalId      String?
  hospital        Hospital?     @relation(fields: [hospitalId], references: [id])
  
  departmentId    String
  department      Department    @relation(fields: [departmentId], references: [id])
  
  encounters      Encounter[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  investigations  Investigation[]
  referrals       Referral[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([hprId])
  @@index([registrationNo])
  @@index([hospitalId])
  @@map("doctors")
}

model Department {
  id           String    @id @default(uuid())
  name         String
  code         String    @unique
  description  String?
  subspecialty String?   // e.g. "Retina", "Cataract", "Squint" for Ophthalmology
  
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  
  facilityId  String
  facility    Facility  @relation(fields: [facilityId], references: [id])
  
  doctors     Doctor[]
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([hospitalId])
  @@map("departments")
}

model Facility {
  id          String         @id @default(uuid())
  hfrId       String?        @unique
  name        String
  type        FacilityType
  address     Json
  contact     Json
  
  departments Department[]
  
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([hfrId])
  @@map("facilities")
}

model Encounter {
  id              String          @id @default(uuid())
  encounterId     String          @unique
  type            EncounterType
  
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor          @relation(fields: [doctorId], references: [id])
  
  chiefComplaint           String
  historyOfPresentIllness  String?
  pastMedicalHistory       String?
  physicalExamination      String?
  provisionalDiagnosis     String?
  diagnosis                String?
  finalDiagnosis           String?
  prescription             Json?
  vitalSigns               Json?
  notes                    String?
  followUpDate             DateTime?
  admissionRequired        Boolean         @default(false)
  referralRequired         Boolean         @default(false)
  
  // OPD Token Flow Fields
  labTestsOrdered          Json?           // Array of lab tests ordered by doctor
  scansOrdered             Json?           // Array of scans/imaging ordered
  labResults               Json?           // Lab test results uploaded by lab tech
  scanResults              Json?           // Scan results
  medicinesDispensed       Boolean         @default(false)
  labTestsCompleted        Boolean         @default(false)
  scansCompleted           Boolean         @default(false)
  billGenerated            Boolean         @default(false)
  consultationFee          Decimal?        @db.Decimal(10, 2)
  labCharges               Decimal?        @db.Decimal(10, 2)
  medicineCharges          Decimal?        @db.Decimal(10, 2)
  scanCharges              Decimal?        @db.Decimal(10, 2)
  totalAmount              Decimal?        @db.Decimal(10, 2)
  paymentStatus            String?         // PENDING, PAID, PARTIAL
  paymentCollected         Decimal?        @db.Decimal(10, 2)
  paymentMethod            String?         // CASH, UPI, CARD, BANK_TRANSFER
  transactionRef           String?
  
  status          EncounterStatus @default(SCHEDULED)
  visitDate       DateTime
  
  careContextId   String?         @unique
  careContext     CareContext?
  
  // IPD: if this encounter is an IPD daily round, link it to the admission
  admissionId     String?
  ipdAdmission    Admission?      @relation("IPDRounds", fields: [admissionId], references: [id])

  appointment     Appointment?
  emrRecords      EmrRecord[]
  prescriptions   EncounterPrescription[]
  labOrders       LabOrder[]
  referrals       Referral[]
  admissions      Admission[]     @relation("OPDAdmissions")
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@index([admissionId])
  @@map("encounters")
}

model EmrRecord {
  id              String      @id @default(uuid())
  
  encounterId     String
  encounter       Encounter   @relation(fields: [encounterId], references: [id])
  
  resourceType    String
  fhirData        Json
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([encounterId])
  @@map("emr_records")
}

model CareContext {
  id              String    @id @default(uuid())
  careContextId   String    @unique
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  encounterId     String    @unique
  encounter       Encounter @relation(fields: [encounterId], references: [id])
  
  display         String
  referenceNumber String?
  
  hipId           String
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([careContextId])
  @@map("care_contexts")
}

model Consent {
  id              String         @id @default(uuid())
  consentId       String         @unique
  
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  
  requesterId     String
  requesterName   String?
  purpose         ConsentPurpose
  
  hiTypes         String[]
  dateRange       Json
  
  status          ConsentStatus  @default(REQUESTED)
  grantedAt       DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  
  abdmRequestId   String?
  abdmConsentId   String?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([patientId])
  @@index([status])
  @@index([consentId])
  @@map("consents")
}

model Appointment {
  id              String            @id @default(uuid())
  appointmentId   String            @unique
  
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  
  hospitalId      String?
  hospital        Hospital?         @relation(fields: [hospitalId], references: [id])
  
  scheduledAt     DateTime
  duration        Int               @default(30)
  
  type            AppointmentType   @default(OPD)
  status          AppointmentStatus @default(SCHEDULED)
  
  checkedInAt     DateTime?
  opdCardNumber   String?           @unique
  encounterId     String?           @unique
  encounter       Encounter?        @relation(fields: [encounterId], references: [id])
  
  notes           String?
  payments        Payment[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([scheduledAt])
  @@map("appointments")
}

model Prescription {
  id              String    @id @default(uuid())
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor    @relation(fields: [doctorId], references: [id])
  
  encounterId     String?
  admissionId     String?   // set when prescription originates from IPD round
  
  medications     Json      // Array of {name, dosage, frequency, duration, instructions, price?, quantity?}
  diagnosis       String?
  notes           String?
  
  // Pharmacy dispensing
  status          String    @default("PENDING")  // PENDING, DISPENSED, CANCELLED
  dispensedAt     DateTime?
  dispensedBy     String?   // User id of pharmacist
  totalCharges    Decimal?  @db.Decimal(10, 2)
  
  issuedAt        DateTime  @default(now())
  validUntil      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([issuedAt])
  @@index([status])
  @@map("prescriptions")
}

model Vitals {
  id              String    @id @default(uuid())
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  encounterId     String?
  
  temperature     Float?    // Celsius
  bloodPressureSystolic   Int?
  bloodPressureDiastolic  Int?
  heartRate       Int?      // BPM
  respiratoryRate Int?      // Breaths per minute
  oxygenSaturation Float?   // SpO2 percentage
  weight          Float?    // kg
  height          Float?    // cm
  bmi             Float?
  
  recordedBy      String?
  notes           String?
  
  recordedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([recordedAt])
  @@map("vitals")
}

model Investigation {
  id              String              @id @default(uuid())
  
  patientId       String
  patient         Patient             @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor              @relation(fields: [doctorId], references: [id])
  
  hospitalId      String
  hospital        Hospital            @relation(fields: [hospitalId], references: [id])
  
  encounterId     String?
  
  testName        String
  testType        String              // LAB, RADIOLOGY, etc.
  instructions    String?
  
  status          InvestigationStatus @default(ORDERED)
  priority        String?             // ROUTINE, URGENT, STAT
  
  orderedAt       DateTime            @default(now())
  sampleCollectedAt DateTime?
  resultEnteredAt   DateTime?
  reportedAt        DateTime?
  
  results         Json?
  reportUrl       String?
  notes           String?
  amount          Decimal?  @db.Decimal(10, 2)   // test charge set by lab tech / admin
  admissionId     String?                          // if ordered during IPD stay
  
  labTechnicianId String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([status])
  @@index([orderedAt])
  @@map("investigations")
}

model Payment {
  id              String        @id @default(uuid())
  
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  
  hospitalId      String
  hospital        Hospital      @relation(fields: [hospitalId], references: [id])
  
  appointmentId   String?
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])

  admissionId     String?       // Link IPD payments to an admission
  admission       Admission?    @relation(fields: [admissionId], references: [id])
  
  amount          Float
  paymentMethod   PaymentMethod
  status          PaymentStatus @default(PENDING)
  
  transactionId   String?       @unique
  receiptNumber   String?       @unique
  
  description     String?
  items           Json?         // Itemized billing
  
  paidAt          DateTime?
  createdBy       String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([patientId])
  @@index([hospitalId])
  @@index([admissionId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id              String    @id @default(uuid())
  
  action          String
  module          String
  
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  userType        UserType
  
  resourceType    String
  resourceId      String?
  
  ipAddress       String?
  userAgent       String?
  
  requestData     Json?
  responseData    Json?
  
  status          String
  errorMessage    String?
  
  timestamp       DateTime  @default(now())
  
  @@index([userId])
  @@index([timestamp])
  @@index([module])
  @@index([action])
  @@map("audit_logs")
}

model AbdmTransaction {
  id              String    @id @default(uuid())
  
  transactionId   String    @unique
  requestId       String?
  
  apiEndpoint     String
  method          String
  
  requestPayload  Json
  responsePayload Json?
  
  statusCode      Int?
  success         Boolean
  
  errorMessage    String?
  duration        Int?
  
  timestamp       DateTime  @default(now())
  
  @@index([timestamp])
  @@index([success])
  @@map("abdm_transactions")
}

enum HospitalType {
  HOSPITAL
  CLINIC
  NURSING_HOME
  DIAGNOSTIC_CENTER
  POLYCLINIC
  SPECIALTY_CENTER
  MULTI_SPECIALTY
  SUPER_SPECIALTY
}

enum HospitalPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum HospitalStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Hospital {
  id          String   @id @default(uuid())
  
  // Basic Information
  name        String
  code        String   @unique
  type        HospitalType @default(HOSPITAL)
  
  // Contact Information
  email       String   @unique
  phone       String
  alternatePhone String?
  website     String?
  
  // Address Details
  addressLine1 String
  addressLine2 String?
  city        String
  state       String
  country     String   @default("India")
  pincode     String
  landmark    String?
  
  // Legal & Registration
  registrationNumber String? @unique
  gstNumber   String?
  panNumber   String?
  licenseNumber String?
  establishedYear Int?
  
  // Admin/Owner Details
  primaryAdminId String? @unique
  ownerName   String?
  ownerEmail  String?
  ownerPhone  String?
  
  // Facility Details
  totalBeds   Int?     @default(0)
  icuBeds     Int?     @default(0)
  emergencyBeds Int?   @default(0)
  operationTheaters Int? @default(0)
  
  // Services Offered
  services    String[] @default([])
  specialties String[] @default([])
  
  // Subscription & Plan
  plan        HospitalPlan    @default(FREE)
  
  // Default OPD charges (used if doctor has no individual fee set)
  defaultOpdCharge Decimal?  @db.Decimal(10, 2)
  status      HospitalStatus  @default(TRIAL)
  trialEndsAt DateTime?
  trialStartedAt DateTime?
  subscriptionStartedAt DateTime?
  subscriptionEndsAt DateTime?
  
  // Plan Limits
  maxUsers    Int      @default(5)
  maxDoctors  Int      @default(3)
  maxPatients Int      @default(100)
  maxStorage  Int      @default(1024) // in MB
  
  // Billing
  billingCycle BillingCycle @default(MONTHLY)
  nextBillingDate DateTime?
  lastPaymentDate DateTime?
  totalRevenue Float    @default(0)
  
  // ABDM Integration
  hipId       String?  @unique
  hiuId       String?  @unique
  abdmEnabled Boolean  @default(false)
  abdmRegisteredAt DateTime?
  
  // Settings
  timezone    String   @default("Asia/Kolkata")
  currency    String   @default("INR")
  language    String   @default("en")
  
  // Status & Verification
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  verifiedAt  DateTime?
  verifiedBy  String?
  
  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingStep Int     @default(1)
  
  // Relations
  users       User[]
  doctors     Doctor[]
  patients    Patient[]
  appointments Appointment[]
  departments  Department[]
  investigations Investigation[]
  payments     Payment[]
  wards        Ward[]
  admissions   Admission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([code])
  @@index([email])
  @@index([status])
  @@index([plan])
  @@index([isActive])
  @@map("hospitals")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String
  
  firstName     String
  lastName      String
  
  role          UserRole
  
  hospitalId    String?
  hospital      Hospital?      @relation(fields: [hospitalId], references: [id])
  
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  
  notifications Notification[]
  auditLogs     AuditLog[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  @@index([email])
  @@index([username])
  @@index([hospitalId])
  @@map("users")
}

model Notification {
  id        String           @id @default(uuid())
  
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType @default(INFO)
  title     String
  message   String
  category  String           @default("system")
  
  read      Boolean          @default(false)
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EncounterType {
  OPD
  IPD
  EMERGENCY
  TELECONSULTATION
}

enum EncounterStatus {
  SCHEDULED           // Initial state
  CHECKED_IN          // Patient checked in, waiting for doctor
  CONSULTING          // With doctor
  IN_PROGRESS         // Consultation in progress (legacy, same as CONSULTING)
  LAB_PENDING         // Lab tests ordered, waiting for lab
  LAB_IN_PROGRESS     // Lab tech working on tests
  LAB_COMPLETED       // Lab tests done
  SCAN_PENDING        // Scans ordered, waiting for radiology
  SCAN_IN_PROGRESS    // Radiology working on scans
  SCAN_COMPLETED      // Scans done
  PHARMACY_PENDING    // Medicines prescribed, waiting for pharmacy
  PHARMACY_COMPLETED  // Medicines dispensed
  BILLING_PENDING     // Ready for billing
  COMPLETED           // All done, bill paid
  CANCELLED           // Appointment cancelled
}

enum ConsentStatus {
  REQUESTED
  GRANTED
  DENIED
  EXPIRED
  REVOKED
}

enum ConsentPurpose {
  CARE_MANAGEMENT
  BREAK_THE_GLASS
  PUBLIC_HEALTH
  DISEASE_SPECIFIC_HEALTHCARE_RESEARCH
}

enum KycStatus {
  PENDING
  VERIFIED
  FAILED
}

enum UserType {
  PATIENT
  DOCTOR
  ADMIN
  SYSTEM
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  LAB_TECHNICIAN
  PHARMACIST
  BILLING_STAFF
  RADIOLOGIST
}

enum FacilityType {
  HOSPITAL
  CLINIC
  DIAGNOSTIC_CENTER
  PHARMACY
}

enum AppointmentType {
  OPD                  // Out-Patient Department - General consultation
  IPD                  // In-Patient Department - Admission required
  EMERGENCY            // Emergency consultation
  FOLLOW_UP            // Follow-up visit after treatment
  TELECONSULTATION     // Remote video/phone consultation
  ROUTINE_CHECKUP      // Regular health checkup
  VACCINATION          // Vaccination appointment
  DIAGNOSTIC           // Diagnostic tests (X-ray, MRI, etc.)
  SURGERY_CONSULTATION // Pre/Post surgery consultation
  SECOND_OPINION       // Second opinion consultation
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum InvestigationStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NET_BANKING
  INSURANCE
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
  CANCELLED
}

model EncounterPrescription {
  id            String    @id @default(uuid())
  encounterId   String
  encounter     Encounter @relation(fields: [encounterId], references: [id])
  
  medicineName  String
  dosage        String
  frequency     String
  duration      String
  instructions  String?
  quantity      Int?
  price         Decimal?  @db.Decimal(10, 2)   // unit price set by admin/pharmacist
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([encounterId])
  @@map("encounter_prescriptions")
}

model LabOrder {
  id            String      @id @default(uuid())
  orderId       String      @unique
  encounterId   String
  encounter     Encounter   @relation(fields: [encounterId], references: [id])
  
  testName      String
  testType      String?
  priority      OrderPriority @default(ROUTINE)
  status        OrderStatus   @default(PENDING)
  
  results       Json?
  resultNotes   String?
  
  orderedAt     DateTime    @default(now())
  completedAt   DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([encounterId])
  @@index([status])
  @@map("lab_orders")
}

model Referral {
  id                String         @id @default(uuid())
  referralId        String         @unique
  encounterId       String
  encounter         Encounter      @relation(fields: [encounterId], references: [id])
  
  referredToDoctorId String
  referredToDoctor   Doctor        @relation(fields: [referredToDoctorId], references: [id])
  
  reason            String
  notes             String?
  urgency           ReferralUrgency @default(ROUTINE)
  status            ReferralStatus  @default(PENDING)
  
  appointmentDate   DateTime?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  @@index([encounterId])
  @@index([referredToDoctorId])
  @@index([status])
  @@map("referrals")
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderPriority {
  ROUTINE
  URGENT
  STAT
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ReferralUrgency {
  ROUTINE
  URGENT
  EMERGENCY
}

// ─── IPD / Ward / Admission ─────────────────────────────────────────────────

enum WardType {
  GENERAL
  ICU
  PRIVATE
  SEMI_PRIVATE
  NICU
  HDU
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGED
  TRANSFERRED
  ABSCONDED
}

model Ward {
  id           String    @id @default(uuid())
  name         String
  type         WardType  @default(GENERAL)
  floor        String?
  totalBeds    Int       @default(0)
  dailyCharges Float     @default(0)   // Standard per-day rate set by admin
  hospitalId   String
  hospital     Hospital  @relation(fields: [hospitalId], references: [id])
  
  beds        Bed[]
  admissions  Admission[]

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([hospitalId])
  @@map("wards")
}

model Bed {
  id         String    @id @default(uuid())
  bedNumber  String
  wardId     String
  ward       Ward      @relation(fields: [wardId], references: [id])
  status     BedStatus @default(AVAILABLE)
  
  admissions Admission[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([wardId, bedNumber])
  @@index([wardId])
  @@index([status])
  @@map("beds")
}

model Admission {
  id               String          @id @default(uuid())
  admissionNumber  String          @unique

  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id])

  // Optional link to the OPD encounter that triggered admission
  encounterId      String?
  encounter        Encounter?      @relation("OPDAdmissions", fields: [encounterId], references: [id])

  wardId           String
  ward             Ward            @relation(fields: [wardId], references: [id])

  bedId            String?
  bed              Bed?            @relation(fields: [bedId], references: [id])

  hospitalId       String
  hospital         Hospital        @relation(fields: [hospitalId], references: [id])

  admittedBy       String?         // Doctor name / userId
  admittedAt       DateTime        @default(now())
  dischargedAt     DateTime?

  admissionReason  String?
  diagnosis        String?
  notes            String?

  dailyCharges     Float           @default(0)
  advancePaid      Float           @default(0)
  totalAmount      Float           @default(0)

  // Payment settlement on discharge
  paymentCollected  Float?
  paymentMethod     String?         // CASH, UPI, CARD, BANK_TRANSFER
  transactionRef    String?         // UPI transaction ID / card ref / bank ref
  paymentSettledAt  DateTime?
  paymentStatus     String?         @default("PENDING") // PENDING, PARTIAL, PAID

  status           AdmissionStatus @default(ADMITTED)

  // Doctor marks patient ready; receptionist then processes payment + discharge
  dischargeReadyAt   DateTime?
  dischargeReadyBy   String?         // Doctor userId who marked ready

  payments         Payment[]
  rounds           Encounter[]     @relation("IPDRounds")

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([patientId])
  @@index([hospitalId])
  @@index([wardId])
  @@index([status])
  @@map("admissions")
}
