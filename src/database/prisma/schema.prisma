generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String        @id @default(uuid())
  uhid             String        @unique
  
  // ABDM Identity (Cross-Hospital)
  // NOTE: abhaId / abhaNumber are NOT globally unique. The same person can be
  // registered as a patient at multiple hospitals (ABHA is the national identity;
  // the Patient row is hospital-local). Uniqueness is enforced per-hospital via
  // the composite @@unique declarations at the bottom of this model.
  abhaId           String?
  abhaAddress      String?
  abhaNumber       String?
  
  // Basic Info
  firstName        String
  lastName         String
  middleName       String?
  gender           Gender
  dob              DateTime?
  mobile           String
  email            String?
  address          Json
  bloodGroup       String?
  emergencyContact Json?
  maritalStatus    String?
  occupation       String?
  allergies        String[]      @default([])
  medicalHistory   Json?         // { pastMedical: string[], familyHistory: string[], chronicConditions: string[] }
  
  // Hospital that registered the patient
  // Patient data can be shared across hospitals via ABDM Consent model
  hospitalId       String?
  hospital         Hospital?     @relation(fields: [hospitalId], references: [id])
  
  isCrossHospital  Boolean       @default(false)
  isActive         Boolean       @default(true)

  // Where this patient row originated. Drives the "Incomplete profile" CTA on
  // the Patient page and lets the front desk filter for rows that still need
  // intake (typically SCAN_SHARE rows where ABDM only sent a sparse profile).
  registrationSource PatientRegistrationSource @default(WALK_IN)
  // Receptionist marks this true after they've filled in the missing fields
  // (mobile, address, bloodGroup, emergency contact). Drives the banner.
  profileCompleted Boolean       @default(true)

  // Relations
  abhaRecord              AbhaRecord?
  encounters              Encounter[]
  consents                Consent[]
  appointments            Appointment[]
  careContexts            CareContext[]
  prescriptions           Prescription[]
  vitals                  Vitals[]
  investigations          Investigation[]
  payments                Payment[]
  admissions              Admission[]
  documents               Document[]
  externalHealthRecords   ExternalHealthRecord[]
  immunizations           Immunization[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  @@index([abhaId])
  @@index([abhaNumber])
  @@index([mobile])
  @@index([uhid])
  @@index([hospitalId])

  // Per-hospital uniqueness — same ABHA / mobile may exist at different hospitals
  // (one person, multiple hospital records). NULL hospitalId rows are treated as
  // distinct by Postgres, which is the desired behavior for legacy data.
  @@unique([hospitalId, abhaId], map: "patients_hospital_abhaId_unique")
  @@unique([hospitalId, abhaNumber], map: "patients_hospital_abhaNumber_unique")
  @@unique([hospitalId, mobile], map: "patients_hospital_mobile_unique")
  @@map("patients")
}

model AbhaRecord {
  id              String    @id @default(uuid())
  // Global per-ABHA enrollment / KYC cache. Keep @unique so a single canonical
  // record exists per national ABHA number. Patient<->ABHA per-hospital linkage
  // is on Patient.abhaNumber (with @@unique([hospitalId, abhaNumber])); the
  // patientId pointer below is informational and reflects the latest hospital
  // that linked this ABHA.
  abhaNumber      String    @unique
  abhaAddress     String?
  patientId       String?   @unique
  
  aadhaarLinked   Boolean   @default(false)
  mobileLinked    Boolean   @default(false)
  
  kycStatus       KycStatus @default(PENDING)
  // ABDM lifecycle status from /v0.5/patients/status/notify (M2 deactivate/opt-out)
  profileStatus   AbhaProfileStatus @default(ACTIVE)
  deactivatedAt   DateTime?
  profileData     Json?
  
  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([abhaNumber])
  @@index([profileStatus])
  @@map("abha_records")
}

model Doctor {
  id              String        @id @default(uuid())
  hprId           String?       @unique
  firstName       String
  lastName        String
  specialization  String
  qualification   String
  registrationNo  String        @unique
  mobile          String
  email           String
  isActive        Boolean       @default(true)
  consultationFee Decimal?      @db.Decimal(10, 2)   // OPD fee set by admin
  
  // Scheduling Configuration
  workingHours      Json?       // Override hospital hours per doctor, same format as operatingHours
  slotDuration      Int?        // Override hospital default (minutes)
  maxPatientsPerDay Int         @default(30)
  breakTimes        Json?       // Doctor-specific breaks
  
  userId          String?       @unique
  user            User?         @relation(fields: [userId], references: [id])
  
  hospitalId      String?
  hospital        Hospital?     @relation(fields: [hospitalId], references: [id])
  
  departmentId    String
  department      Department    @relation(fields: [departmentId], references: [id])
  
  encounters      Encounter[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  investigations  Investigation[]
  referrals       Referral[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([hprId])
  @@index([registrationNo])
  @@index([hospitalId])
  @@map("doctors")
}

model Department {
  id           String    @id @default(uuid())
  name         String
  code         String
  description  String?
  subspecialty String?   // e.g. "Retina", "Cataract", "Squint" for Ophthalmology
  
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  
  facilityId  String
  facility    Facility  @relation(fields: [facilityId], references: [id])
  
  doctors     Doctor[]
  users       User[]
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@map("departments")
}

model Facility {
  id          String         @id @default(uuid())
  hfrId       String?        @unique
  name        String
  type        FacilityType
  address     Json
  contact     Json
  
  departments Department[]
  
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([hfrId])
  @@map("facilities")
}

model Encounter {
  id              String          @id @default(uuid())
  encounterId     String          @unique
  type            EncounterType
  
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor          @relation(fields: [doctorId], references: [id])
  
  chiefComplaint           String
  historyOfPresentIllness  String?
  pastMedicalHistory       String?
  physicalExamination      String?
  provisionalDiagnosis     String?
  diagnosis                String?
  finalDiagnosis           String?
  prescription             Json?
  vitalSigns               Json?
  notes                    String?
  followUpDate             DateTime?
  admissionRequired        Boolean         @default(false)
  // Clinical reason captured by the doctor when they tick "Recommend
  // admission" during the consultation. Surfaced on the appointment row,
  // patient profile and IPD admit dialog so the receptionist / admin doesn't
  // have to ask the doctor again.
  admissionReason          String?
  referralRequired         Boolean         @default(false)
  
  // OPD Token Flow Fields
  labTestsOrdered          Json?           // Array of lab tests ordered by doctor
  scansOrdered             Json?           // Array of scans/imaging ordered
  labResults               Json?           // Lab test results uploaded by lab tech
  scanResults              Json?           // Scan results
  medicinesDispensed       Boolean         @default(false)
  labTestsCompleted        Boolean         @default(false)
  scansCompleted           Boolean         @default(false)
  billGenerated            Boolean         @default(false)
  consultationFee          Decimal?        @db.Decimal(10, 2)
  labCharges               Decimal?        @db.Decimal(10, 2)
  medicineCharges          Decimal?        @db.Decimal(10, 2)
  scanCharges              Decimal?        @db.Decimal(10, 2)
  totalAmount              Decimal?        @db.Decimal(10, 2)
  paymentStatus            String?         // PENDING, PAID, PARTIAL
  paymentCollected         Decimal?        @db.Decimal(10, 2)
  paymentMethod            String?         // CASH, UPI, CARD, BANK_TRANSFER
  transactionRef           String?
  discountAmount           Decimal?        @db.Decimal(10, 2) @default(0)
  discountReason           String?
  discountApprovedBy       String?
  
  version         Int             @default(1)
  status          EncounterStatus @default(SCHEDULED)
  visitDate       DateTime
  
  careContextId   String?         @unique
  careContext     CareContext?
  
  // IPD: if this encounter is an IPD daily round, link it to the admission
  admissionId     String?
  ipdAdmission    Admission?      @relation("IPDRounds", fields: [admissionId], references: [id])

  appointment     Appointment?
  emrRecords      EmrRecord[]
  prescriptions   EncounterPrescription[]
  labOrders       LabOrder[]
  referrals       Referral[]
  admissions      Admission[]     @relation("OPDAdmissions")
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@index([admissionId])
  @@map("encounters")
}

model EmrRecord {
  id              String      @id @default(uuid())
  
  encounterId     String
  encounter       Encounter   @relation(fields: [encounterId], references: [id])
  
  resourceType    String
  fhirData        Json
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([encounterId])
  @@map("emr_records")
}

model CareContext {
  id              String    @id @default(uuid())
  careContextId   String    @unique
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  encounterId     String    @unique
  encounter       Encounter @relation(fields: [encounterId], references: [id])
  
  display         String
  referenceNumber String?
  
  hipId           String
  linkStatus      String    @default("PENDING") // PENDING, LINKED, FAILED
  linkToken       String?
  
  // ABDM link-audit detail — surfaced in the UI so staff can see exactly what
  // happened, when, and why a link failed.
  hiType          String?   // Derived ABDM HI type advertised for this context (OPConsultation, Prescription, …)
  linkedAt        DateTime? // When ABDM confirmed the link (on_carecontext SUCCESS)
  linkError       String?   // Failure reason from ABDM when linkStatus = FAILED
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([careContextId])
  @@map("care_contexts")
}

model Consent {
  id              String         @id @default(uuid())
  consentId       String         @unique
  
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  
  requesterId     String
  requesterName   String?
  requesterHospitalId String?
  requesterHospital   Hospital? @relation("RequesterHospital", fields: [requesterHospitalId], references: [id])
  purpose         ConsentPurpose
  
  hiTypes         String[]
  dateRange       Json
  
  status          ConsentStatus  @default(REQUESTED)
  grantedAt       DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  // Set by the consent-expiry sweeper / on-notify revoke handlers when the
  // associated ExternalHealthRecord and ConsentKeyPair rows have been wiped.
  purgedAt        DateTime?
  
  abdmRequestId   String?
  abdmConsentId   String?
  // Full consent artefact body delivered via /api/v3/hiu/consents/on-fetch.
  // Persisted so the HIU can re-validate scope (hiTypes, dateRange, expiry,
  // signatures) at read-time before exposing data to clinicians.
  artefactBody    Json?
  artefactFetchedAt DateTime?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([patientId])
  @@index([status])
  @@index([consentId])
  @@index([abdmConsentId])
  @@index([expiresAt])
  @@map("consents")
}

model Appointment {
  id              String            @id @default(uuid())
  appointmentId   String            @unique
  
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  
  hospitalId      String?
  hospital        Hospital?         @relation(fields: [hospitalId], references: [id])
  
  scheduledAt     DateTime
  duration        Int               @default(30)
  
  type            AppointmentType   @default(OPD)
  status          AppointmentStatus @default(SCHEDULED)
  
  checkedInAt     DateTime?
  opdCardNumber   String?           @unique
  encounterId     String?           @unique
  encounter       Encounter?        @relation(fields: [encounterId], references: [id])
  
  notes           String?
  payments        Payment[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([scheduledAt])
  @@map("appointments")
}

model Prescription {
  id              String    @id @default(uuid())
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor    @relation(fields: [doctorId], references: [id])
  
  encounterId     String?
  admissionId     String?   // set when prescription originates from IPD round
  
  medications     Json      // Array of {name, dosage, frequency, duration, instructions, price?, quantity?}
  diagnosis       String?
  notes           String?
  
  // Pharmacy dispensing
  status          String    @default("PENDING")  // PENDING, DISPENSED, CANCELLED
  dispensedAt     DateTime?
  dispensedBy     String?   // User id of pharmacist
  totalCharges    Decimal?  @db.Decimal(10, 2)
  
  issuedAt        DateTime  @default(now())
  validUntil      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([issuedAt])
  @@index([status])
  @@map("prescriptions")
}

model Vitals {
  id              String    @id @default(uuid())
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  encounterId     String?
  
  temperature     Float?    // Celsius
  bloodPressureSystolic   Int?
  bloodPressureDiastolic  Int?
  heartRate       Int?      // BPM
  respiratoryRate Int?      // Breaths per minute
  oxygenSaturation Float?   // SpO2 percentage
  weight          Float?    // kg
  height          Float?    // cm
  bmi             Float?
  
  recordedBy      String?
  notes           String?
  
  recordedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([recordedAt])
  @@map("vitals")
}

model Investigation {
  id              String              @id @default(uuid())
  
  patientId       String
  patient         Patient             @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor              @relation(fields: [doctorId], references: [id])
  
  hospitalId      String
  hospital        Hospital            @relation(fields: [hospitalId], references: [id])
  
  encounterId     String?
  
  testName        String
  testType        String              // LAB, RADIOLOGY, etc.
  instructions    String?
  
  status          InvestigationStatus @default(ORDERED)
  priority        String?             // ROUTINE, URGENT, STAT
  
  orderedAt       DateTime            @default(now())
  sampleCollectedAt DateTime?
  resultEnteredAt   DateTime?
  reportedAt        DateTime?
  
  results         Json?
  reportUrl       String?
  notes           String?
  amount          Decimal?  @db.Decimal(10, 2)   // test charge set by lab tech / admin
  admissionId     String?                          // if ordered during IPD stay
  
  labTechnicianId String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([status])
  @@index([orderedAt])
  @@map("investigations")
}

model Payment {
  id              String        @id @default(uuid())
  
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  
  hospitalId      String
  hospital        Hospital      @relation(fields: [hospitalId], references: [id])
  
  appointmentId   String?
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])

  admissionId     String?       // Link IPD payments to an admission
  admission       Admission?    @relation(fields: [admissionId], references: [id])
  
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  status          PaymentStatus @default(PENDING)
  version         Int           @default(1)
  
  transactionId   String?       @unique
  receiptNumber   String?       @unique
  
  description     String?
  items           Json?         // Itemized billing
  
  paidAt          DateTime?
  createdBy       String?

  // Who actually collected the money at the counter. Distinct from
  // `createdBy` because in some flows (e.g. an admin generates a bill, the
  // receptionist later collects) those are different people. We need a
  // proper FK so admin reports / dashboards can group cleanly by staff.
  collectedById   String?
  collectedBy     User?         @relation("PaymentCollector", fields: [collectedById], references: [id])
  collectedAt     DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([patientId])
  @@index([hospitalId])
  @@index([admissionId])
  @@index([status])
  @@index([createdAt])
  @@index([collectedById])
  @@map("payments")
}

model AuditLog {
  id              String    @id @default(uuid())
  
  action          String
  module          String
  
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  userType        UserType
  
  resourceType    String
  resourceId      String?
  
  ipAddress       String?
  userAgent       String?
  
  requestData     Json?
  responseData    Json?
  
  status          String
  errorMessage    String?
  
  timestamp       DateTime  @default(now())
  
  @@index([userId])
  @@index([timestamp])
  @@index([module])
  @@index([action])
  @@map("audit_logs")
}

model AbdmTransaction {
  id              String    @id @default(uuid())
  
  transactionId   String    @unique
  requestId       String?
  
  apiEndpoint     String
  method          String
  
  requestPayload  Json
  responsePayload Json?
  
  statusCode      Int?
  success         Boolean
  
  errorMessage    String?
  duration        Int?
  
  timestamp       DateTime  @default(now())
  
  @@index([timestamp])
  @@index([success])
  @@map("abdm_transactions")
}

enum HospitalType {
  HOSPITAL
  CLINIC
  NURSING_HOME
  DIAGNOSTIC_CENTER
  POLYCLINIC
  SPECIALTY_CENTER
  MULTI_SPECIALTY
  SUPER_SPECIALTY
}

enum HospitalPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum HospitalStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Hospital {
  id          String   @id @default(uuid())
  
  // Basic Information
  name        String
  code        String   @unique
  type        HospitalType @default(HOSPITAL)
  
  // Contact Information
  email       String   @unique
  phone       String
  alternatePhone String?
  website     String?
  
  // Address Details
  addressLine1 String
  addressLine2 String?
  city        String
  state       String
  country     String   @default("India")
  pincode     String
  landmark    String?
  
  // Legal & Registration
  registrationNumber String? @unique
  gstNumber   String?
  panNumber   String?
  licenseNumber String?
  establishedYear Int?
  
  // Admin/Owner Details
  primaryAdminId String? @unique
  ownerName   String?
  ownerEmail  String?
  ownerPhone  String?
  
  // Facility Details
  totalBeds   Int?     @default(0)
  icuBeds     Int?     @default(0)
  emergencyBeds Int?   @default(0)
  operationTheaters Int? @default(0)
  
  // Services Offered
  services    String[] @default([])
  specialties String[] @default([])
  
  // Subscription & Plan
  plan        HospitalPlan    @default(FREE)
  
  // Default OPD charges (used if doctor has no individual fee set)
  defaultOpdCharge Decimal?  @db.Decimal(10, 2)
  status      HospitalStatus  @default(TRIAL)
  trialEndsAt DateTime?
  trialStartedAt DateTime?
  subscriptionStartedAt DateTime?
  subscriptionEndsAt DateTime?
  
  // Plan Limits
  maxUsers    Int      @default(5)
  maxDoctors  Int      @default(3)
  maxPatients Int      @default(100)
  maxStorage  Int      @default(1024) // in MB
  
  // Billing
  billingCycle BillingCycle @default(MONTHLY)
  nextBillingDate DateTime?
  lastPaymentDate DateTime?
  totalRevenue Decimal  @default(0) @db.Decimal(12, 2)
  
  // ─── ABDM Integration (facility-level identifiers) ────────────────────
  // Each tenant acts as its own HIP/HIU bridge. Identifiers come from the
  // ABDM Health Facility Registry (HFR) — `hfrFacilityId` is the canonical
  // HFR Facility ID, while `hipId` / `hiuId` are the bridge-side service
  // identifiers (typically equal to the HFR ID for a facility that's both
  // a HIP and a HIU). HPR ids belong on Doctor (per-clinician), NOT here.
  hipId            String?  @unique
  hipName          String?
  hiuId            String?  @unique
  hiuName          String?
  abdmClientId     String?
  abdmClientSecret String?
  abdmCallbackUrl  String?
  hfrFacilityId    String?  @unique
  abdmEnabled      Boolean  @default(false)
  abdmRegisteredAt DateTime?
  
  // Settings
  timezone    String   @default("Asia/Kolkata")
  currency    String   @default("INR")
  language    String   @default("en")
  
  // Scheduling Configuration
  operatingHours     Json?      // { "mon": { "start": "08:00", "end": "22:00" }, ... } null day = closed
  defaultSlotDuration Int       @default(30)
  breakTimes         Json?      // [{ "start": "13:00", "end": "14:00", "label": "Lunch" }]
  holidays           Json?      // ["2026-01-26", "2026-08-15"]
  is24x7             Boolean    @default(false)
  
  // Status & Verification
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  verifiedAt  DateTime?
  verifiedBy  String?
  
  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingStep Int     @default(1)
  
  // Relations
  users       User[]
  doctors     Doctor[]
  patients    Patient[]
  appointments Appointment[]
  departments  Department[]
  investigations Investigation[]
  payments     Payment[]
  wards        Ward[]
  admissions   Admission[]
  documents    Document[]
  medicines    Medicine[]
  inventoryBatches InventoryBatch[]
  consentsRequested Consent[] @relation("RequesterHospital")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([code])
  @@index([email])
  @@index([status])
  @@index([plan])
  @@index([isActive])
  @@map("hospitals")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String
  
  firstName     String
  lastName      String
  phone         String?
  
  role          UserRole
  
  hospitalId    String?
  hospital      Hospital?      @relation(fields: [hospitalId], references: [id])
  
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id])
  
  wardId        String?
  ward          Ward?          @relation(fields: [wardId], references: [id])
  
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  
  doctor        Doctor?
  notifications Notification[]
  auditLogs     AuditLog[]
  paymentsCollected Payment[]  @relation("PaymentCollector")
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  @@index([email])
  @@index([username])
  @@index([hospitalId])
  @@index([departmentId])
  @@index([wardId])
  @@map("users")
}

model Notification {
  id        String           @id @default(uuid())
  
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType @default(INFO)
  title     String
  message   String
  category  String           @default("system")
  
  read      Boolean          @default(false)
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// How a Patient row first entered our system. Drives UX cues like the
// "Incomplete profile" banner and registration-source filters in the patient
// list. Add new values rather than renaming existing ones.
enum PatientRegistrationSource {
  WALK_IN          // standard front-desk registration
  SCAN_SHARE       // patient scanned the facility QR via PHR app
  ABHA_VERIFY      // created during a manual ABHA Verify lookup
