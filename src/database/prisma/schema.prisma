// ─── IPD / Ward / Admission ─────────────────────────────────────────────────

enum WardType {
  GENERAL
  ICU
  PRIVATE
  SEMI_PRIVATE
  NICU
  HDU
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
}

enum AdmissionStatus {
  ADMITTED
  DISCHARGE_READY
  DISCHARGED
  TRANSFERRED
  ABSCONDED
}

model Ward {
  id           String    @id @default(uuid())
  name         String
  type         WardType  @default(GENERAL)
  floor        String?
  totalBeds    Int       @default(0)
  dailyCharges Decimal   @default(0) @db.Decimal(12, 2)
  hospitalId   String
  hospital     Hospital  @relation(fields: [hospitalId], references: [id])
  
  beds        Bed[]
  admissions  Admission[]
  users       User[]
  transfersFrom BedTransfer[] @relation("TransferFromWard")
  transfersTo   BedTransfer[] @relation("TransferToWard")

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([hospitalId])
  @@map("wards")
}

model Bed {
  id         String    @id @default(uuid())
  bedNumber  String
  wardId     String
  ward       Ward      @relation(fields: [wardId], references: [id])
  status     BedStatus @default(AVAILABLE)

  // Bed features
  bedType         BedType        @default(STANDARD)
  hasOxygen       Boolean        @default(false)
  hasVentilator   Boolean        @default(false)
  hasMonitor      Boolean        @default(false)
  hasSuction      Boolean        @default(false)

  // Housekeeping
  cleaningStatus  CleaningStatus @default(CLEAN)
  lastCleanedAt   DateTime?
  lastCleanedBy   String?

  // Maintenance
  maintenanceNote  String?
  maintenanceFrom  DateTime?
  maintenanceTo    DateTime?
  
  admissions Admission[]
  transfersFrom BedTransfer[] @relation("TransferFromBed")
  transfersTo   BedTransfer[] @relation("TransferToBed")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([wardId, bedNumber])
  @@index([wardId])
  @@index([status])
  @@map("beds")
}

model Admission {
  id               String          @id @default(uuid())
  admissionNumber  String          @unique

  patientId        String
  patient          Patient         @relation(fields: [patientId], references: [id])

  // Optional link to the OPD encounter that triggered admission
  encounterId      String?
  encounter        Encounter?      @relation("OPDAdmissions", fields: [encounterId], references: [id])

  wardId           String
  ward             Ward            @relation(fields: [wardId], references: [id])

  bedId            String?
  bed              Bed?            @relation(fields: [bedId], references: [id])

  hospitalId       String
  hospital         Hospital        @relation(fields: [hospitalId], references: [id])

  admittedBy       String?         // Doctor name / userId
  admittedAt       DateTime        @default(now())
  dischargedAt     DateTime?

  admissionReason  String?
  diagnosis        String?
  notes            String?

  dailyCharges     Decimal         @default(0) @db.Decimal(12, 2)
  advancePaid      Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal         @default(0) @db.Decimal(12, 2)

  // Payment settlement on discharge
  paymentCollected  Decimal?        @db.Decimal(12, 2)
  paymentMethod     String?         // CASH, UPI, CARD, BANK_TRANSFER
  transactionRef    String?         // UPI transaction ID / card ref / bank ref
  paymentSettledAt  DateTime?
  paymentStatus     String?         @default("PENDING") // PENDING, PARTIAL, PAID

  status           AdmissionStatus @default(ADMITTED)
  version          Int             @default(1)

  // Discount (admin-only)
  discountAmount     Decimal         @default(0) @db.Decimal(12, 2)
  discountReason     String?
  discountApprovedBy String?

  // Doctor marks patient ready; receptionist then processes payment + discharge
  dischargeReadyAt   DateTime?
  dischargeReadyBy   String?         // Doctor userId who marked ready

  payments         Payment[]
  rounds           Encounter[]     @relation("IPDRounds")
  transfers        BedTransfer[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([patientId])
  @@index([hospitalId])
  @@index([wardId])
  @@index([status])
  @@map("admissions")
}

