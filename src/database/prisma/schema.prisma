generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id               String        @id @default(uuid())
  uhid             String        @unique
  
  // ABDM Identity (Cross-Hospital)
  abhaId           String?       @unique
  abhaAddress      String?
  abhaNumber       String?       @unique
  
  // Basic Info
  firstName        String
  lastName         String
  gender           Gender
  dob              DateTime
  mobile           String        @unique
  email            String?
  address          Json
  bloodGroup       String?
  emergencyContact Json?
  
  // Patient is NOT owned by hospital
  // Access is controlled via Consent model
  isActive         Boolean       @default(true)
  
  // Relations
  abhaRecord       AbhaRecord?
  encounters       Encounter[]
  consents         Consent[]
  appointments     Appointment[]
  careContexts     CareContext[]
  prescriptions    Prescription[]
  vitals           Vitals[]
  investigations   Investigation[]
  payments         Payment[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  @@index([abhaId])
  @@index([abhaNumber])
  @@index([mobile])
  @@index([uhid])
  @@map("patients")
}

model AbhaRecord {
  id              String    @id @default(uuid())
  abhaNumber      String    @unique
  abhaAddress     String?
  patientId       String?   @unique
  
  aadhaarLinked   Boolean   @default(false)
  mobileLinked    Boolean   @default(false)
  
  kycStatus       KycStatus @default(PENDING)
  profileData     Json?
  
  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([abhaNumber])
  @@map("abha_records")
}

model Doctor {
  id              String        @id @default(uuid())
  hprId           String?       @unique
  firstName       String
  lastName        String
  specialization  String
  qualification   String
  registrationNo  String        @unique
  mobile          String
  email           String
  isActive        Boolean       @default(true)
  
  hospitalId      String?
  hospital        Hospital?     @relation(fields: [hospitalId], references: [id])
  
  departmentId    String
  department      Department    @relation(fields: [departmentId], references: [id])
  
  encounters      Encounter[]
  appointments    Appointment[]
  prescriptions   Prescription[]
  investigations  Investigation[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([hprId])
  @@index([registrationNo])
  @@index([hospitalId])
  @@map("doctors")
}

model Department {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  description String?
  
  hospitalId  String?
  hospital    Hospital? @relation(fields: [hospitalId], references: [id])
  
  facilityId  String
  facility    Facility  @relation(fields: [facilityId], references: [id])
  
  doctors     Doctor[]
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([hospitalId])
  @@map("departments")
}

model Facility {
  id          String         @id @default(uuid())
  hfrId       String?        @unique
  name        String
  type        FacilityType
  address     Json
  contact     Json
  
  departments Department[]
  
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([hfrId])
  @@map("facilities")
}

model Encounter {
  id              String          @id @default(uuid())
  encounterId     String          @unique
  type            EncounterType
  
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor          @relation(fields: [doctorId], references: [id])
  
  chiefComplaint  String
  diagnosis       String?
  prescription    Json?
  vitalSigns      Json?
  notes           String?
  
  status          EncounterStatus @default(SCHEDULED)
  visitDate       DateTime
  
  careContextId   String?         @unique
  careContext     CareContext?
  
  emrRecords      EmrRecord[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@map("encounters")
}

model EmrRecord {
  id              String      @id @default(uuid())
  
  encounterId     String
  encounter       Encounter   @relation(fields: [encounterId], references: [id])
  
  resourceType    String
  fhirData        Json
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([encounterId])
  @@map("emr_records")
}

model CareContext {
  id              String    @id @default(uuid())
  careContextId   String    @unique
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  encounterId     String    @unique
  encounter       Encounter @relation(fields: [encounterId], references: [id])
  
  display         String
  referenceNumber String?
  
  hipId           String
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([careContextId])
  @@map("care_contexts")
}

model Consent {
  id              String         @id @default(uuid())
  consentId       String         @unique
  
  patientId       String
  patient         Patient        @relation(fields: [patientId], references: [id])
  
  requesterId     String
  requesterName   String?
  purpose         ConsentPurpose
  
  hiTypes         String[]
  dateRange       Json
  
  status          ConsentStatus  @default(REQUESTED)
  grantedAt       DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  
  abdmRequestId   String?
  abdmConsentId   String?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([patientId])
  @@index([status])
  @@index([consentId])
  @@map("consents")
}

model Appointment {
  id              String            @id @default(uuid())
  appointmentId   String            @unique
  
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  
  hospitalId      String?
  hospital        Hospital?         @relation(fields: [hospitalId], references: [id])
  
  scheduledAt     DateTime
  duration        Int               @default(30)
  
  type            AppointmentType   @default(OPD)
  status          AppointmentStatus @default(SCHEDULED)
  
  notes           String?
  payments        Payment[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([scheduledAt])
  @@map("appointments")
}

model Prescription {
  id              String    @id @default(uuid())
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor    @relation(fields: [doctorId], references: [id])
  
  encounterId     String?
  
  medications     Json      // Array of {name, dosage, frequency, duration, instructions}
  diagnosis       String?
  notes           String?
  
  issuedAt        DateTime  @default(now())
  validUntil      DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([issuedAt])
  @@map("prescriptions")
}

model Vitals {
  id              String    @id @default(uuid())
  
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  
  encounterId     String?
  
  temperature     Float?    // Celsius
  bloodPressureSystolic   Int?
  bloodPressureDiastolic  Int?
  heartRate       Int?      // BPM
  respiratoryRate Int?      // Breaths per minute
  oxygenSaturation Float?   // SpO2 percentage
  weight          Float?    // kg
  height          Float?    // cm
  bmi             Float?
  
  recordedBy      String?
  notes           String?
  
  recordedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([patientId])
  @@index([recordedAt])
  @@map("vitals")
}

model Investigation {
  id              String              @id @default(uuid())
  
  patientId       String
  patient         Patient             @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Doctor              @relation(fields: [doctorId], references: [id])
  
  hospitalId      String
  hospital        Hospital            @relation(fields: [hospitalId], references: [id])
  
  encounterId     String?
  
  testName        String
  testType        String              // LAB, RADIOLOGY, etc.
  instructions    String?
  
  status          InvestigationStatus @default(ORDERED)
  priority        String?             // ROUTINE, URGENT, STAT
  
  orderedAt       DateTime            @default(now())
  sampleCollectedAt DateTime?
  resultEnteredAt   DateTime?
  reportedAt        DateTime?
  
  results         Json?
  reportUrl       String?
  notes           String?
  
  labTechnicianId String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([status])
  @@index([orderedAt])
  @@map("investigations")
}

model Payment {
  id              String        @id @default(uuid())
  
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  
  hospitalId      String
  hospital        Hospital      @relation(fields: [hospitalId], references: [id])
  
  appointmentId   String?
  appointment     Appointment?  @relation(fields: [appointmentId], references: [id])
  
  amount          Float
  paymentMethod   PaymentMethod
  status          PaymentStatus @default(PENDING)
  
  transactionId   String?       @unique
  receiptNumber   String?       @unique
  
  description     String?
  items           Json?         // Itemized billing
  
  paidAt          DateTime?
  createdBy       String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([patientId])
  @@index([hospitalId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model AuditLog {
  id              String    @id @default(uuid())
  
  action          String
  module          String
  
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  userType        UserType
  
  resourceType    String
  resourceId      String?
  
  ipAddress       String?
  userAgent       String?
  
  requestData     Json?
  responseData    Json?
  
  status          String
  errorMessage    String?
  
  timestamp       DateTime  @default(now())
  
  @@index([userId])
  @@index([timestamp])
  @@index([module])
  @@index([action])
  @@map("audit_logs")
}

model AbdmTransaction {
  id              String    @id @default(uuid())
  
  transactionId   String    @unique
  requestId       String?
  
  apiEndpoint     String
  method          String
  
  requestPayload  Json
  responsePayload Json?
  
  statusCode      Int?
  success         Boolean
  
  errorMessage    String?
  duration        Int?
  
  timestamp       DateTime  @default(now())
  
  @@index([timestamp])
  @@index([success])
  @@map("abdm_transactions")
}

enum HospitalPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum HospitalStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

model Hospital {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  
  // Contact & Location
  address     String?
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  
  // Subscription & Plan
  plan        HospitalPlan    @default(FREE)
  status      HospitalStatus  @default(TRIAL)
  trialEndsAt DateTime?
  subscriptionEndsAt DateTime?
  
  // ABDM Integration
  hipId       String?  @unique
  hiuId       String?  @unique
  abdmEnabled Boolean  @default(false)
  
  // Primary Admin (Hospital Owner)
  primaryAdminId String? @unique
  
  // Limits based on plan
  maxUsers    Int      @default(5)
  maxPatients Int      @default(100)
  
  isActive    Boolean  @default(true)
  
  // Relations
  users       User[]
  doctors     Doctor[]
  appointments Appointment[]
  departments  Department[]
  investigations Investigation[]
  payments     Payment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([code])
  @@index([status])
  @@index([plan])
  @@map("hospitals")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  password      String
  
  firstName     String
  lastName      String
  
  role          UserRole
  
  hospitalId    String?
  hospital      Hospital?      @relation(fields: [hospitalId], references: [id])
  
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  
  notifications Notification[]
  auditLogs     AuditLog[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  @@index([email])
  @@index([username])
  @@index([hospitalId])
  @@map("users")
}

model Notification {
  id        String           @id @default(uuid())
  
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType @default(INFO)
  title     String
  message   String
  category  String           @default("system")
  
  read      Boolean          @default(false)
  
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EncounterType {
  OPD
  IPD
  EMERGENCY
  TELECONSULTATION
}

enum EncounterStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ConsentStatus {
  REQUESTED
  GRANTED
  DENIED
  EXPIRED
  REVOKED
}

enum ConsentPurpose {
  CARE_MANAGEMENT
  BREAK_THE_GLASS
  PUBLIC_HEALTH
  DISEASE_SPECIFIC_HEALTHCARE_RESEARCH
}

enum KycStatus {
  PENDING
  VERIFIED
  FAILED
}

enum UserType {
  PATIENT
  DOCTOR
  ADMIN
  SYSTEM
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  LAB_TECHNICIAN
  PHARMACIST
}

enum FacilityType {
  HOSPITAL
  CLINIC
  DIAGNOSTIC_CENTER
  PHARMACY
}

enum AppointmentType {
  OPD
  TELECONSULTATION
  FOLLOW_UP
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum InvestigationStatus {
  ORDERED
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NET_BANKING
  INSURANCE
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
  CANCELLED
}
