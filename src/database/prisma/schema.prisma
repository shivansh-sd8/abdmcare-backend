model ReceivedShare {
  id             String   @id @default(uuid())
  hospitalId     String?
  abhaNumber     String
  abhaAddress    String?
  name           String
  gender         String?
  mobile         String?
  tokenNumber    String?
  requestId      String?
  rawProfile     Json?
  receivedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  // Lifecycle. PENDING shares need front-desk action (convert to a new
  // Patient, merge into an existing one, or ignore). The Patient row is no
  // longer auto-created — see hip.controller.handleProfileShare.
  status            ReceivedShareStatus @default(PENDING)
  convertedPatientId String?
  convertedAt        DateTime?
  convertedById      String?           // user.id of the receptionist who acted
  notes              String?           // free text the receptionist may attach

  @@index([hospitalId])
  @@index([abhaNumber])
  @@index([status])
  @@map("received_shares")
}

// HIU-side ECDH keypair held while a data flow is in-flight.
//
// Lookup keys (in priority order, see hiu.service.ts:receiveHealthInformation):
//   • `consentId`     — the abdm consent UUID (always known when sending /cm/request)
//   • `requestId`     — our REQUEST-ID header on /cm/request; matched by the
//                       gateway in /health-information/on-request callbacks
//   • `transactionId` — the gateway-issued transaction id on the on-request
//                       callback; also the one and only id present on the
//                       subsequent /data/notification push from the HIP. We
//                       MUST be able to correlate by transactionId because the
//                       data push body never carries a consent reference.
model ConsentKeyPair {
  id            String   @id @default(uuid())
  consentId     String   @unique
  requestId     String?  @unique
  transactionId String?  @unique
  privateKey    String
  nonce         String
  createdAt     DateTime @default(now())
  @@index([consentId])
  @@index([requestId])
  @@index([transactionId])
  @@map("consent_key_pairs")
}

// Vaccination / Immunization rows. Drives the M2 ImmunizationRecord FHIR profile
// (Composition.type SNOMED 41000179103). One row = one administered dose.
model Immunization {
  id              String    @id @default(uuid())

  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])

  // Optional encounter that the dose was administered at (used to attach this
  // record to a CareContext during M2 linking).
  encounterId     String?

  // Vaccine identification
  vaccineName     String
  vaccineCode     String?   // SNOMED-CT or HL7 v3 code (e.g. ChAdOx1-S 871751008)
  manufacturer    String?
  lotNumber       String?
  expiryDate      DateTime?

  // Administration
  doseNumber      Int?
  totalDoses      Int?
  site            String?   // SNOMED body-site code or text
  route           String?   // SNOMED route code or text (IM, SC, PO …)
  doseQuantity   Decimal?  @db.Decimal(8, 3)
  doseUnit        String?   // mL by default
  administeredAt  DateTime
  administeredBy  String?   // doctor/nurse user id

  // Optional clinical context
  reason          String?
  notes           String?

  hospitalId      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([patientId])
  @@index([encounterId])
  @@index([administeredAt])
  @@map("immunizations")
}

model ExternalHealthRecord {
  id            String   @id @default(uuid())
  patientId     String
  // FK to the Consent.consentId (not row id) under which this data was pulled.
  // Required so the consent-revoke / consent-expire cascade can deterministically
  // wipe records that are no longer authorised. Not nullable for new rows; we
  // keep it as nullable on the column for backwards compatibility with already
  // ingested data, but the HIU pipeline always sets it.
  consentId     String?
  // Hospital that requested the consent. Used for multi-tenant scoping so
  // Hospital A cannot read records pulled by Hospital B even if the patient
  // is registered at both.
  hospitalId    String?
  sourceHipId   String?
  sourceHipName String?
  recordType    String
  recordDate    DateTime?
  rawBundle     Json
  parsedData    Json
  receivedAt    DateTime @default(now())
  patient       Patient  @relation(fields: [patientId], references: [id])
  @@index([patientId])
  @@index([consentId])
  @@index([hospitalId])
  @@map("external_health_records")
}

