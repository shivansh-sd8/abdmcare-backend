# Application
NODE_ENV=development
PORT=3000
APP_NAME=MediSync ABDM
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medisync_dev?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ABDM Configuration
ABDM_BASE_URL=https://dev.abdm.gov.in
ABDM_CLIENT_ID=your-client-id
ABDM_CLIENT_SECRET=your-client-secret
ABDM_CALLBACK_URL=http://localhost:3000/callbacks

# HIP Configuration
HIP_ID=your-hip-id
HIP_NAME=Your Hospital Name

# HIU Configuration
HIU_ID=your-hiu-id
HIU_NAME=Your Hospital Name

# Encryption
RSA_PUBLIC_KEY_PATH=./keys/public.pem
RSA_PRIVATE_KEY_PATH=./keys/private.pem
AES_ENCRYPTION_KEY=your-32-character-aes-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# CORS
CORS_ORIGIN=http://localhost:3001

# Sentry (Error Tracking)
SENTRY_DSN=

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@medisync.com

# SMS (Optional)
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Session
SESSION_SECRET=your-session-secret-change-this
