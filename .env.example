# Application
# For local: development, For production: production
NODE_ENV=development
PORT=8080
APP_NAME=AbhaAyushman ABDM
APP_VERSION=1.0.0
# Server timezone — should always be Asia/Kolkata so dashboards / "today"
# stats agree with the user's IST wall clock. The Node process also pins
# this internally, but Render / Docker images often default to UTC, which
# can shift third-party libs.
TZ=Asia/Kolkata

# Database
# Local: postgresql://postgres:postgres@localhost:5432/abhaayushman_dev?schema=public
# Production: Use Render PostgreSQL URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/abhaayushman_dev?schema=public

# Redis (Optional - app works without it)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ABDM V3 Configuration
# ──────────────────────────────────────────────────────────────────────────────
# V3 Gateway — session token, bridge management, scan-and-share
ABDM_GATEWAY_URL=https://dev.abdm.gov.in/api/hiecm/gateway/v3
# V3 ABHA — all enrollment, login, profile APIs (sandbox)
ABDM_ABHA_URL=https://abhasbx.abdm.gov.in/abha/api
# V3 PHR — ABHA address verification
ABDM_PHR_URL=https://abhasbx.abdm.gov.in/abha/api/v3/phr/web
# V3 Facility — HIP/HIU service registration
ABDM_FACILITY_URL=https://facilitysbx.abdm.gov.in
# Bridge ID issued by ABDM (e.g. SBXID_035154 for sandbox)
ABDM_CLIENT_ID=your-bridge-id
ABDM_CLIENT_SECRET=your-client-secret
# Public HTTPS URL where ABDM will call your HIP/HIU callbacks
# Must be https:// with a valid SSL cert
# For local testing: use cloudflared or ngrok
ABDM_CALLBACK_URL=https://your-backend-domain.com
# X-CM-ID header: 'sbx' for sandbox, 'abdm' for production
ABDM_CM_ID=sbx

# ─────────────────────────────────────────────────────────────────────────────
# HIP / HIU IDENTIFIERS
#
# IMPORTANT: HIP & HIU IDs are now stored PER-HOSPITAL in the `hospitals`
# table (`hipId`, `hiuId`, `hfrFacilityId`, `hprId`-on-doctor). Do NOT rely on
# these env values for runtime — they exist only as defaults that admins can
# pre-populate when seeding new tenants. The Facility QR endpoint reads
# strictly from the database; it will refuse to issue a QR for a hospital
# that has no HFR/HIP id.
# ─────────────────────────────────────────────────────────────────────────────
# HIP_ID=your-bridge-id        # legacy / seed-only
# HIP_NAME=Your Hospital Name  # legacy / seed-only
# HIU_ID=your-bridge-id        # legacy / seed-only
# HIU_NAME=Your Hospital Name  # legacy / seed-only

# Public deep-link host the ABHA / PHR app expects inside a Health Facility QR.
# Defaults: phrsbx.abdm.gov.in (sandbox) or phr.abdm.gov.in (when ABDM_CM_ID=abdm)
# Override only if ABDM publishes a new host.
# ABDM_SCAN_SHARE_BASE_URL=https://phrsbx.abdm.gov.in

# Encryption
RSA_PUBLIC_KEY_PATH=./keys/public.pem
RSA_PRIVATE_KEY_PATH=./keys/private.pem
AES_ENCRYPTION_KEY=your-32-character-aes-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# CORS (comma-separated for multiple origins)
# Local development
# CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Production (Vercel + Custom Domain)
CORS_ORIGIN=https://abdmcare-frontend-50dyfwa6u-shivanshs-projects-89b8fbd6.vercel.app,https://abdmcare-frontend.vercel.app,https://www.abhaayushman.com,https://abhaayushman.com,http://localhost:3000

# Sentry (Error Tracking)
SENTRY_DSN=

# Email (Optional — required for the public enquiry form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Set to true for port 465 (TLS-from-start). Leave blank for STARTTLS on 587.
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@abhaayushman.com
# Where landing-page enquiries land. Comma-separated for multiple recipients.
ENQUIRY_TO_EMAILS=hello@abhaayushman.com

# SMS (Optional)
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Session
SESSION_SECRET=your-session-secret-change-this
